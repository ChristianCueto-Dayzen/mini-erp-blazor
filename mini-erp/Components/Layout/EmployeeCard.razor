<!-- Employee Card: Muestra en forma de tabla los datos obtenidos en la lista de empleados
    proporcionada por el padre. Incluye un input para filtrar/buscar empleados.
-->
@inject IRepository repository

<EmployeeForm empleado="employee" OnAdd="AddEmployeeAsync" />

<br />  
<div class="row justify-content-end">
    <input class="form-control" style="max-width: 300px; margin:0 8px" @bind="searchInput" @bind:after="Search"
        @bind:event="oninput" placeholder="Search:"/>
    <button class="btn btn-outline-primary" style="max-width: 80px" @onclick ="Clear">Clear</button>
</div>

<br />
<input type="checkbox" @bind="ShowDeleteButton" class="form-check-input" />
<span>
    Show Delete Button
</span>
<br />
<table class="table table-striped table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th class="text-center">Name</th>
            <th class="text-center">Position</th>
            <th class="text-center">Email</th>
            <th class="text-center">Salary</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (employees is null)
        {
            <tr>
                <td colspan="5">Loading employees...</td>
            </tr>
        }
        else if (IsLoading)
        {
            <tr>
                <td colspan="5">Loading employees...</td>
            </tr>
        }
        else if (employees.Count == 0)
        {
            <tr>
                <td colspan="5">No employees found.</td>
            </tr>
        }
        else
        {
            @foreach (var employee in employees)
            {
                <tr>
                    <td>@employee.Name</td>
                    <td>@employee.Position</td>
                    <td>@employee.Email</td>
                    <td class="text-end">$@employee.Salary</td>
                    <td class="text-center">
                        @if (ShowDeleteButton)
                        {
                            <button class="btn btn-danger btn-sm"
                                    disabled="@IsLoading"
                                    @onclick="() => DeleteEmployeeAsync(employee)">
                                Delete
                            </button>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                </tr>

            }
        }
        }
    </tbody>
</table>

@code {

    bool ShowDeleteButton = false;
    bool IsLoading = false;
    private Employee employee { get; set; } = new();
    string searchInput = string.Empty;

    [Parameter]
    [EditorRequired]
    public List<Employee>? employees { get; set; }

    protected async Task Search()
    {
        IsLoading = true;
        await Task.Delay(2000);

        if (string.IsNullOrWhiteSpace(searchInput))
        {
            employees = repository.GetEmployees();
        }
        else
        {
            employees = repository.GetEmployees()
                                  .Where(e => e.Name.Contains(searchInput, StringComparison.OrdinalIgnoreCase) ||
                                              e.Position.Contains(searchInput, StringComparison.OrdinalIgnoreCase) ||
                                              e.Email.Contains(searchInput, StringComparison.OrdinalIgnoreCase))
                                  .ToList();
        }
        IsLoading = false;
    }

    protected async Task Clear()
    {
        if(!string.IsNullOrWhiteSpace(searchInput))
        {
            IsLoading = false;
            searchInput = "";
            await Task.Delay(2000);
            await Search();
            IsLoading = false;
        }
    }

    protected async Task DeleteEmployeeAsync(Employee employee)
    {
        IsLoading = true;
        await Task.Delay(2000);
        repository.DeleteEmployee(employee);
        IsLoading = false;
    }

    private async Task AddEmployeeAsync()
    {
        await Task.Delay(2000);
        repository.AddEmployee(employee);
        employee = new Employee();
    }
}
