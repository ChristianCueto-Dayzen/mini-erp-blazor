<!-- Employee Card: Muestra en forma de tabla los datos obtenidos en la lista de empleados
    proporcionada por el padre. Incluye un input para filtrar/buscar empleados.
-->
@inject IRepository repository

<EmployeeForm empleado="employee" OnAdd="AddEmployeeAsync" />

<br />
<div class="row justify-content-end">
    <input class="form-control" style="max-width: 300px; margin:0 4px" @bind="searchInput" @bind:event="oninput" @bind:after="Find" placeholder="Search:" />
    @*<input class="form-control" style="max-width: 300px; margin:0 4px" @bind="searchInput" placeholder="Search:" />*@
    <InputSelect class="form-select" style="max-width: 150px; margin:0 4px"
        @bind-Value="searchOption" @bind-Value:after="Find">

        <option class="text-opacity-25" value="">--Search by--</option>
        <option value="Name">Name</option>
        <option value="Position">Position</option>
        <option value="Email">Email</option>
    </InputSelect>

    @* <button class="btn btn-outline-primary" style="max-width: 80px; margin: 0 4px" @onclick="Find">Find</button> *@
    <button class="btn btn-outline-secondary" style="max-width: 80px" @onclick="Clear">Clear</button>
</div>


<input type="checkbox" @bind="ShowDeleteButton" class="form-check-input" />
<span>
    Show Delete Button
</span>
<br />
<table class="table table-striped table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th class="text-center">Name</th>
            <th class="text-center">Position</th>
            <th class="text-center">Email</th>
            <th class="text-center">Salary</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (employees is null || IsLoading)
        {
            <tr>
                <td colspan="5">Loading employees...</td>
            </tr>
        }
        
        else if (employees.Count == 0)
        {
            <tr>
                <td colspan="5">No employees found.</td>
            </tr>
        }
        else
        {
            @foreach (var employee in employees)
            {
                <tr>
                    <td>@employee.Name</td>
                    <td>@employee.Position</td>
                    <td>@employee.Email</td>
                    <td class="text-end">$@employee.Salary</td>
                    <td class="text-center">
                        @if (ShowDeleteButton)
                        {
                            <button class="btn btn-danger btn-sm"
                                    disabled="@IsLoading"
                                    @onclick="() => DeleteEmployeeAsync(employee)">
                                Delete
                            </button>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                </tr>

            }
        }

    </tbody>
</table>

@code {
    string searchOption = string.Empty;
    bool ShowDeleteButton = false;
    bool IsLoading = false;
    bool IsShowingFilteredList = false;
    private Employee employee { get; set; } = new();
    string searchInput = string.Empty;

    [Parameter]
    [EditorRequired]
    public List<Employee>? employees { get; set; }



    protected async Task Find()
    {
        if (!string.IsNullOrEmpty(searchOption) && !string.IsNullOrWhiteSpace(searchInput))
        {
            employees = repository.SearchEmployees(searchOption,searchInput.Trim());
            StateHasChanged();
            IsShowingFilteredList = true;
        }
        else if(IsShowingFilteredList)
        {
            employees = repository.GetEmployees();
            IsShowingFilteredList = false;
        }
    }

    protected async Task Clear()
    {
        if (!string.IsNullOrWhiteSpace(searchInput))
        {
            searchInput = "";
            searchOption = "";
        }
        if (IsShowingFilteredList)
        {
            await Find();
        }
    }

    protected async Task DeleteEmployeeAsync(Employee employee)
    {
        IsLoading = true;
        await Task.Delay(2000);
        repository.DeleteEmployee(employee);
        IsLoading = false;
    }

    private async Task AddEmployeeAsync()
    {
        await Task.Delay(2000);
        repository.AddEmployee(employee);
        employee = new Employee();
    }
}
