<!-- Employee Card: Muestra en forma de tabla los datos obtenidos en la lista de empleados
    proporcionada por el padre.
-->

@inject IRepository repository
<EmployeeForm empleado="employee" OnAdd="AddEmployee" />

<br />
<input type="checkbox" @bind="ShowDeleteButton" class="form-check-input" />
<span>
    Show Delete Button
</span>
<br />

<table class="table table-striped table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th class="text-center">Name</th>
            <th class="text-center">Position</th>
            <th class="text-center">Email</th>
            <th class="text-center">Salary</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (employees is null)
        {
            <tr>
                <td colspan="5">Loading employees...</td>
            </tr>
        }
        else if (employees.Count == 0)
        {
            <tr>
                <td colspan="5">No employees found.</td>
            </tr>
        }
        else
        {
            @foreach (var employee in employees)
            {
                <tr>
                    <td>@employee.Name</td>
                    <td>@employee.Position</td>
                    <td>@employee.Email</td>
                    <td class="text-end">$@employee.Salary</td>
                    <td class="text-center">
                        @if (ShowDeleteButton)
                        {
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => repository.DeleteEmployee(employee)">
                                Delete
                            </button>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@code {

    bool ShowDeleteButton = false;
    private Employee? employee { get; set; } = new();

    [Parameter]
    [EditorRequired]
    public List<Employee>? employees { get; set; }

    private void AddEmployee(Employee emp)
    {
        repository.AddEmployee(emp);
        employee = new Employee();
    }
}
