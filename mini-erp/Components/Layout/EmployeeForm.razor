
<button @onclick="ShowForm">@ShowButton</button>
<hr />
@if (showForm)
{
    <div>
        <p>Enter the new employee information: </p>

        <EditForm Model="empleado" OnValidSubmit="Add">
            <DataAnnotationsValidator />
            <div>
                <label for="name"> Name:</label>
                <div>
                    <InputText @bind-Value="@empleado.Name" /> 
                    <ValidationMessage For="@(() => empleado.Name)" />
                </div>
                <label for="position"> Position:</label>
                <div>
                    <InputText @bind-Value="@empleado.Position" />
                    <ValidationMessage For="@(() => empleado.Position)" />
                </div>
                <label for="email"> Email:</label>
                <div>
                    <InputText @bind-Value="@empleado.Email" />
                    <ValidationMessage For="@(() => empleado.Email)" />
                </div>
                <label for="salary"> Salary:</label>
                <div>
                    <InputNumber @bind-Value="@empleado.Salary" />
                    <ValidationMessage For="@(() => empleado.Salary)" />
                </div>
            </div>
            <br />
            <button type="submit">  Add employee </button>

        </EditForm>
        <br /> 
        


    </div>
    <hr />
}
@code {
    bool showForm = false;
    void ShowForm() { showForm = !showForm; }

    string ShowButton => showForm ? "Hide form" : "Add new employee";

    public void Add()
    {
        OnAdd.InvokeAsync(empleado);
    }

    [Parameter]
    public Employee empleado { get; set; } = null!;

    [Parameter]
    public EventCallback<Employee> OnAdd { get; set; }

    
}
